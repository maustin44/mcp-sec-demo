# ============================================================
#  ToolVault — Backend Environment Variables
# ============================================================
#
#  SETUP:
#    1. Copy this file:  cp .env.example .env
#    2. Fill in the values below
#    3. Start the server: npm run dev
#
#  NOTES:
#    - These values are used as defaults on first startup.
#    - After that, admins can change GitHub settings from
#      the Integrations page (stored in the database).
#    - Never commit your real .env file to git.
#
# ============================================================

# --- Auth ---
# A random string used to sign JWT login tokens.
# Make it long and random.
JWT_SECRET=

# --- GitHub Integration ---
# Personal access token (classic). Use "repo" scope for private + public
# repos, or "public_repo" for public only.
# Generate one at: https://github.com/settings/tokens
GITHUB_TOKEN=

# The GitHub organization name or personal username whose repos
# ToolVault will display (e.g. "malinadettore" or "google").
GITHUB_ORG=

# --- Server ---
# Port the backend runs on (frontend expects 3001).
PORT=3001
